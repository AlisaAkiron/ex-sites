# Public origin of the deployed site (no trailing slash).
# Used to build absolute og:url, og:image, canonical, and sitemap URLs.
APP_URL=https://example.com

# Rybbit analytics (public identifiers, inlined at build time).
# Only initialized in production builds; disabled during `vite dev`.
VITE_RYBBIT_HOST=https://rybbit.example.com/api
VITE_RYBBIT_SITE_ID=your-site-id
